/*
 * Copyright 2024 Nordic Semiconductor ASA
 * SPDX-License-Identifier: Apache-2.0
 *
 * nRF54L15DK - TWI Slave overlay
 *
 * Uses i2c22 (TWIS) as the I2C slave, address 0x54.
 *
 * Physical wiring to the master board:
 *   Slave P1.09  SDA  ----  Master P1.08  SDA
 *   Slave P1.13  SCL  ----  Master P1.12  SCL
 *   GND               ----  GND
 *
 * NOTE: Slave uses P1.09/P1.13 to avoid conflict with DK buttons.
 *
 * status = "okay" is required so that pinctrl_apply_state() can
 * configure P1.09/P1.13 through the nRF54L crossbar.
 * TWIS pins must use NRF_PSEL(TWIS_SDA/SCL) — not TWIM — as the
 * crossbar function selectors are different for slave vs master.
 */

/ {
        aliases {
                i2c-slave = &i2c22;
        };
};

&pinctrl {
        i2c22_default_alt: i2c22_default_alt {
                group1 {
                        psels = <NRF_PSEL(TWIS_SDA, 1, 9)>,
                                <NRF_PSEL(TWIS_SCL, 1, 13)>;
                        bias-pull-up;
                };
        };

        i2c22_sleep_alt: i2c22_sleep_alt {
                group1 {
                        psels = <NRF_PSEL(TWIS_SDA, 1, 9)>,
                                <NRF_PSEL(TWIS_SCL, 1, 13)>;
                        low-power-enable;
                };
        };
};

&i2c22 {
        compatible = "nordic,nrf-twis";
        status = "okay";
        pinctrl-0 = <&i2c22_default_alt>;
        pinctrl-1 = <&i2c22_sleep_alt>;
        pinctrl-names = "default", "sleep";
};